<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Formation Ansible</title>
</head>
<body>

    <h1>Bienvenue sur la plateforme DevOps</h1>

    <p>Projet de formation Ansible et Nginx.</p>

    <h2>Informations du formateur</h2>
    <img src="img/photo.jpeg" alt="Photo-profil" width="400">
    <p>
        Nom : {{ formateur.name }}<br>
        Rôle : {{ formateur.role }}<br>
        Spécialité : {{ formateur.specialite }}<br>
        Contact : {{ formateur.email }}
    </p>

    <h2>Modules</h2>

    <ul>
	{% for module in modules %}
        <li><a href="/{{ module.name }}">voici le lien pour le module --> {{ module.name | title }}</a></li>
	{% endfor %}
    </ul>

</body>
</html>
